# ─────────────────────────────────────────────────────────────────────────────
# Conexión a base de datos (usadas cuando DATABASE_URL no está definida)
#
# Contexto local (pnpm run start):
#   DB_HOST=localhost   ← conecta al postgres de docker-compose expuesto en 5433
#   DB_PORT=5433
#
# Contexto Docker API en la misma red que el contenedor postgres:
#   DB_HOST=postgres    ← nombre del servicio en docker-compose
#   DB_PORT=5432        ← puerto interno del contenedor
# ─────────────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_USER=coworking
DB_PASSWORD=coworking
DB_NAME=coworking_db

# ─────────────────────────────────────────────────────────────────────────────
# Conexión vía URL completa (Railway u otro proveedor cloud).
# Si esta variable está definida, las variables DB_* anteriores se ignoran.
# SSL se activa automáticamente cuando NODE_ENV=production.
# ─────────────────────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─────────────────────────────────────────────────────────────────────────────
# Autenticación JWT
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=changeme
JWT_EXPIRES_IN=30m

# ─────────────────────────────────────────────────────────────────────────────
# Entorno de ejecución (development | production | test)
# Solo en production se aplica ssl: { rejectUnauthorized: false }
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:3001
